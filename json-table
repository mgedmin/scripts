#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "rich>=15.0.0",
# ]
# ///

"""
Read a JSON list of records from stdin or file, format them as a table.
"""

import argparse
import json
import pathlib
import sys

from rich import box
from rich.console import Console
from rich.style import StyleType
from rich.table import Table
from rich.text import Text, TextType
from rich.theme import Theme


parser = argparse.ArgumentParser(description=__doc__.strip())
parser.add_argument("filename", nargs='?', metavar="filename.json")
parser.add_argument(
    "-r",
    "--rename-columns",
    metavar="COL1=FIELD1,COL2=FIELD2,...",
    help="comma-separated list of column names and field names for them",
)
parser.add_argument(
    "-o",
    "--column-order",
    metavar="COL1,COL2,...",
    help=(
        "comma-separated list of columns for changing display order"
        " (columns not listed here will be added in order of appearance)"
    ),
)
parser.add_argument(
    "-H",
    "--hide-columns",
    metavar="COL1,COL2,...",
    help="comma-separated list of columns to remove from output",
)
parser.add_argument(
    "-O",
    "--only-columns",
    metavar="COL1,COL2,...",
    help=(
        "comma-separated list of columns to display"
        " (columns not listed here will be removed from output)"
    ),
)
parser.add_argument(
    "-s",
    "--sort",
    metavar="[,-]COL1,[-]COL2,...",
    help=(
        "comma-separated list of column names for sorting rows"
        " (a - prefix reverses the order)"
    ),
)
parser.add_argument(
    "-W",
    "--no-wrap",
    action='store_true',
    help="truncate table cells instead of wrapping",
)


SIMPLE_ASCII = box.Box(
    "    \n"
    "    \n"
    " -  \n"
    "    \n"
    "    \n"
    " -  \n"
    "    \n"
    "    \n"
)


NULL = 'null'


THEME = Theme({
    'title': 'bright_blue',
    'separator': 'bright_blue',
    'string_value': 'green',
    'numeric_value': 'white',
    'null_value': 'bright_black',
    'other_value': 'white',
    'error': 'red',
})


def value2str(value: object) -> TextType:
    match value:
        case None:
            return Text(NULL, style='null_value')
        case str():
            return Text(value, style='string_value')
        case int() | float():
            return Text(str(value), style='numeric_value')
        case _:
            return Text(str(value), style='other_value')


def print_error(msg: str, style: StyleType = 'error') -> None:
    console = Console(theme=THEME, stderr=True)
    console.print(Text(msg, style='error'))


def main():
    console = Console(theme=THEME)

    args = parser.parse_args()

    if args.only_columns and args.column_order:
        parser.error(
            "--only-columns and --column-order are mutually exclusive"
        )
    if args.only_columns and args.hide_columns:
        parser.error(
            "--only-columns and --hide-columns are mutually exclusive"
        )

    if not args.filename or args.filename == '-':
        if sys.stdin.isatty():
            parser.error('refusing to read from a terminal')
        data = sys.stdin.read()
    else:
        data = pathlib.Path(args.filename).read_text()

    if not data:
        print_error("input is empty")
        sys.exit(1)

    try:
        records = json.loads(data)
    except json.JSONDecodeError as e:
        print_error(f"JSON parse error: {e}")
        lines = data.splitlines()
        if 1 <= e.lineno <= len(lines):
            print_error(lines[e.lineno - 1])
            print_error(f'{"^":>{e.colno}}')
        sys.exit(1)

    if not isinstance(records, list):
        print_error("JSON data is not a list")
        sys.exit(1)

    if not records:
        console.print(Text("no data", style='null_value'))
        return

    # mapping of column names to maximum widths
    # initialize all to 4 in case some rows have missing values
    columns = {}
    min_width = {}
    hide_columns = set()
    if args.hide_columns:
        for c in map(str.strip, args.hide_columns.split(',')):
            if c:
                hide_columns.add(c)
    if args.only_columns:
        for c in map(str.strip, args.only_columns.split(',')):
            if c:
                columns[c] = None
    elif args.column_order:
        for c in map(str.strip, args.column_order.split(',')):
            if c and c not in hide_columns:
                columns[c] = None
    field2col = {}
    col2field = {}
    if args.rename_columns:
        for cf in args.rename_columns.split(","):
            col, _, field = cf.partition('=')
            col = col.strip()
            field = field.strip()
            field2col[field] = col
            col2field[col] = field
    for n, record in enumerate(records):
        if not isinstance(record, dict):
            print_error("Item [{n}] is not an object")
            sys.exit(1)
        for k, v in record.items():
            c = field2col.get(k, k)
            if not args.only_columns and c not in hide_columns:
                columns[c] = None
            if args.no_wrap:
                s = value2str(v)
                if '\n' not in s:
                    min_width[c] = max(min_width.get(c, 0), min(40, len(s)))

    available_space = console.width
    for c in columns:
        is_sensible = 0 < min_width.get(c, 0) < 40
        min_width[c] = max(min_width.get(c, 0), len(c))
        if is_sensible:
            available_space -= min_width[c] - 2

    if args.sort:
        for c in reversed(args.sort.split(',')):
            c = c.strip()
            if not c:
                continue
            reverse = c.startswith('-')
            c = c.removeprefix('-')
            field = col2field.get(c, c)
            records.sort(
                key=lambda r: (str(type(r.get(field))), r.get(field)),
                reverse=reverse,
            )

    table = Table(
        box=SIMPLE_ASCII,
        show_edge=False,
        pad_edge=False,
        header_style='title',
        border_style='separator',
        padding=(0, 1, 0, 0),
    )
    for c in columns:
        table.add_column(
            c,
            no_wrap=args.no_wrap,
            min_width=min_width.get(c),
            max_width=available_space,
        )

    for record in records:
        table.add_row(
            *(
                value2str(record.get(col2field.get(c, c)))
                for c in columns
            )
        )
    console.print(table)


if __name__ == "__main__":
    main()
